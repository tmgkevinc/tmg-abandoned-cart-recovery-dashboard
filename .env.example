TMG_DATA_HUB_BASE_URL=https://your-data-hub.example.com
TMG_DATA_HUB_API_KEY=replace_with_your_server_side_api_key
TEAM_API_KEY_DASHBOARD_EDITOR=replace_with_dashboard_editor_api_key
HOST=0.0.0.0
PORT=4174
ASSIGNMENTS_FILE=lead-assignments.json

# Local testing: manual. Production behind Cloudflare Access: cloudflare_access.
DASHBOARD_AUTH_MODE=manual

# Used when DASHBOARD_AUTH_MODE=cloudflare_access.
ADMIN_EMAILS=admin@example.com
SALES_EMAIL_MAP=johnny@example.com=Johnny;steven@example.com=Steven;brian@example.com=Brian

# Optional. Enable only after Data Hub provides this write endpoint.
DATA_HUB_ASSIGNMENTS_WRITE_PATH=/api/data-hub/lead-assignments/upsert

# Optional. Enable only after Data Hub provides this read endpoint.
DATA_HUB_ASSIGNMENTS_READ_PATH=/api/data-hub/reports/lead-assignments
